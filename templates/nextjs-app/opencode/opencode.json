{
  "$schema": "https://opencode.ai/config.json",
  "model": "alibaba/qwen3.5-plus",
  "default_agent": "build",
  "permission": {
    "edit": "auto",
    "bash": "auto"
  },
  "compaction": {
    "enabled": true,
    "threshold": 0.7
  },
  "mcp": {
    "vercel": {
      "type": "local",
      "command": ["npx", "-y", "@vercel/mcp"],
      "environment": {
        "VERCEL_TOKEN": "env:VERCEL_TOKEN"
      }
    }
  }
}
