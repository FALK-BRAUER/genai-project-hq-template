{
  "$schema": "https://opencode.ai/config.json",
  "model": "alibaba/qwen3.5-plus",
  "default_agent": "build",
  "permission": {
    "edit": "auto",
    "bash": "auto"
  },
  "formatter": {
    "*.py": "python -m black"
  },
  "compaction": {
    "enabled": true,
    "threshold": 0.7
  },
  "mcp": {
    "postgres": {
      "type": "local",
      "command": ["npx", "-y", "@modelcontextprotocol/server-postgres"],
      "environment": {
        "DATABASE_URL": "env:DATABASE_URL"
      }
    }
  }
}
