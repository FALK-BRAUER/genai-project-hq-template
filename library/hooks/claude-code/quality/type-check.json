{
  "event": "PostToolUse",
  "description": "Run TypeScript type check hint after .ts/.tsx write",
  "hooks": [
    {
      "matcher": "Write(*.ts)",
      "hooks": [{"type": "command", "command": "npx tsc --noEmit 2>&1 | head -20", "blocking": false}]
    },
    {
      "matcher": "Write(*.tsx)",
      "hooks": [{"type": "command", "command": "npx tsc --noEmit 2>&1 | head -20", "blocking": false}]
    }
  ]
}
