{
  "event": "PostToolUse",
  "description": "Auto-format TypeScript/TSX/CSS files after write",
  "hooks": [
    {
      "matcher": "Write(*.ts)",
      "hooks": [{"type": "command", "command": "npx prettier --write $file"}]
    },
    {
      "matcher": "Write(*.tsx)",
      "hooks": [{"type": "command", "command": "npx prettier --write $file"}]
    },
    {
      "matcher": "Write(*.css)",
      "hooks": [{"type": "command", "command": "npx prettier --write $file"}]
    }
  ]
}
