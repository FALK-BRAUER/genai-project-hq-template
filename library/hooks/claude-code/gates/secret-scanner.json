{
  "event": "PreToolUse",
  "description": "Scan for exposed secrets before commit using truffleHog",
  "hooks": [
    {
      "matcher": "Bash(git commit*)",
      "hooks": [{
        "type": "command",
        "command": "trufflehog git file://. --only-verified --fail 2>&1 | tail -10",
        "blocking": true
      }]
    }
  ]
}
