# .env.example — reference for environment variables used by this repo
# Do NOT put real credentials here. Store secrets in macOS Keychain (see README.md).

# Keychain entry names used by tools/scripts/env.sh
# Add these via:
#   security add-generic-password -a "$USER" -s ANTHROPIC_API_KEY_HQ -w "sk-ant-..."
ANTHROPIC_API_KEY_HQ=<stored in Keychain>

# Telegram notification credentials (per-account, see notify-telegram.sh)
# security add-generic-password -a "hq" -s HQ_TELEGRAM_BOT_TOKEN -w "..."
# security add-generic-password -a "hq" -s HQ_TELEGRAM_CHAT_ID -w "..."
HQ_TELEGRAM_BOT_TOKEN=<stored in Keychain>
HQ_TELEGRAM_CHAT_ID=<stored in Keychain>

# GitHub repo for issue creation (used by create-issue.sh)
# Can also be set in your shell profile
GITHUB_REPO=YOUR_GITHUB_USER/genai-project-hq-template
